<Window x:Class="FitnessTrainerPlatform.Windows.TrainerProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trainer Profile"
        Height="620" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBackground}">
    <Border Background="White" CornerRadius="8" Margin="16" Padding="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="NameText" FontSize="24" FontWeight="Bold"/>
                <TextBlock x:Name="RatingText" Foreground="#F5A623" FontSize="16" Margin="0,4,0,12"/>
                <TextBlock x:Name="FeeText" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <TextBlock Text="About" FontWeight="Bold"/>
                <TextBlock x:Name="BioText" TextWrapping="Wrap" Foreground="#65676B" Margin="0,4,0,12"/>

                <TextBlock Text="Qualifications" FontWeight="Bold"/>
                <ItemsControl x:Name="QualificationsList" Margin="0,4,0,12"/>

                <TextBlock Text="Prerequisites" FontWeight="Bold"/>
                <ItemsControl x:Name="PrerequisitesList" Margin="0,4,0,12"/>

                <TextBlock Text="Reviews" FontWeight="Bold"/>
                <ItemsControl x:Name="ReviewsList" Margin="0,4,0,12"/>

                <StackPanel x:Name="UserActions" Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Request Tutelage" Click="RequestTutelage_Click"/>
                    <Button Content="Leave Review" Style="{StaticResource SecondaryButton}" Margin="12,0,0,0" Click="LeaveReview_Click"/>
                </StackPanel>

                <StackPanel x:Name="TrainingSection" Visibility="Collapsed" Margin="0,16,0,0">
                    <TextBlock Text="Your Trainings" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ListBox x:Name="TrainingsList" Height="150" SelectionChanged="TrainingsList_SelectionChanged"/>
                    <Button Content="Complete Training &amp; Reply" Margin="0,8,0,0" Click="ReplyTraining_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
