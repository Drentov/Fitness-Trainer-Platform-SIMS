<Window x:Class="FitnessTrainerPlatform.Windows.TrainingReplyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Training Reply"
        Height="340" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBackground}">
    <Border Background="White" Margin="16" Padding="20" CornerRadius="8">
        <StackPanel>
            <TextBlock Text="How was this training?" FontWeight="Bold" FontSize="16"/>
            <ComboBox x:Name="StarsCombo" Margin="0,12,0,12" SelectedIndex="3">
                <ComboBoxItem Content="★★★★★ (5)"/>
                <ComboBoxItem Content="★★★★☆ (4)"/>
                <ComboBoxItem Content="★★★☆☆ (3)"/>
                <ComboBoxItem Content="★★☆☆☆ (2)"/>
                <ComboBoxItem Content="★☆☆☆☆ (1)"/>
            </ComboBox>
            <TextBlock Text="Your opinion" Foreground="#65676B"/>
            <TextBox x:Name="OpinionBox" AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                     Text="It was okay, I struggled with the last exercise..."/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" Margin="0,0,8,0"/>
                <Button Content="Submit Reply" Click="Submit_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
