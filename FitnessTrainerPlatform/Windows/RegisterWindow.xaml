<Window x:Class="FitnessTrainerPlatform.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register - FitTrain"
        Height="600" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource PageBackground}">
    <Border Background="White" CornerRadius="12" Margin="24" Padding="24">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Create Account" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

                <TextBlock Text="Account type" Foreground="#65676B"/>
                <ComboBox x:Name="RoleCombo" Margin="0,4,0,12" SelectedIndex="0">
                    <ComboBoxItem Content="User (client)"/>
                    <ComboBoxItem Content="Trainer (requires admin approval)"/>
                </ComboBox>

                <TextBlock Text="Full name" Foreground="#65676B"/>
                <TextBox x:Name="FullNameBox"/>

                <TextBlock Text="Email" Foreground="#65676B"/>
                <TextBox x:Name="EmailBox"/>

                <TextBlock Text="Username" Foreground="#65676B"/>
                <TextBox x:Name="UsernameBox"/>

                <TextBlock Text="Password" Foreground="#65676B"/>
                <PasswordBox x:Name="PasswordBox"/>

                <StackPanel x:Name="TrainerFields" Visibility="Collapsed">
                    <TextBlock Text="Bio" Foreground="#65676B"/>
                    <TextBox x:Name="BioBox" AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>

                    <TextBlock Text="Qualifications (comma separated)" Foreground="#65676B"/>
                    <TextBox x:Name="QualificationsBox"/>

                    <TextBlock Text="Prerequisites for clients (comma separated)" Foreground="#65676B"/>
                    <TextBox x:Name="PrerequisitesBox"/>

                    <TextBlock Text="Monthly tutelage fee ($)" Foreground="#65676B"/>
                    <TextBox x:Name="FeeBox" Text="29.99"/>
                </StackPanel>

                <StackPanel x:Name="UserFields">
                    <TextBlock Text="Health issues (optional)" Foreground="#65676B"/>
                    <TextBox x:Name="HealthBox" AcceptsReturn="True" Height="50" TextWrapping="Wrap"/>
                </StackPanel>

                <Button Content="Register" Click="Register_Click" Margin="0,8,0,8"/>
                <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Click="Cancel_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
