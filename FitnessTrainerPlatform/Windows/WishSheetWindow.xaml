<Window x:Class="FitnessTrainerPlatform.Windows.WishSheetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Wish Sheet"
        Height="540" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBackground}">
    <Border Background="White" Margin="16" Padding="20" CornerRadius="8">
        <StackPanel>
            <TextBlock Text="User Wish Sheet" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="Help your trainer understand your goals and constraints." Foreground="#65676B" TextWrapping="Wrap" Margin="0,0,0,16"/>

            <TextBlock Text="Goals you hope to achieve" Foreground="#65676B"/>
            <TextBox x:Name="GoalsBox" AcceptsReturn="True" Height="70" TextWrapping="Wrap"
                     Text="e.g. Lose 5kg, sprint 1km without stopping"/>

            <TextBlock Text="When &amp; where you prefer to exercise" Foreground="#65676B"/>
            <CheckBox x:Name="GymCheck" Content="Gym" Margin="0,4,0,0"/>
            <CheckBox x:Name="HomeCheck" Content="Home" Margin="0,4,0,0"/>
            <CheckBox x:Name="OutdoorsCheck" Content="Outdoors" Margin="0,4,0,12"/>

            <TextBlock Text="Schedule notes" Foreground="#65676B"/>
            <TextBox x:Name="ScheduleBox" AcceptsReturn="True" Height="50" TextWrapping="Wrap"
                     Text="e.g. Weekday evenings, Saturday mornings"/>

            <TextBlock Text="Health issues / disabilities" Foreground="#65676B"/>
            <TextBox x:Name="HealthBox" AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" Margin="0,0,8,0"/>
                <Button Content="Submit Request" Click="Submit_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
