<UserControl x:Class="FitnessTrainerPlatform.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TabControl>
        <TabItem Header="Pending Trainers">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid x:Name="PendingGrid" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                        <DataGridTextColumn Header="Qualifications" Binding="{Binding Qualifications}" Width="2*"/>
                        <DataGridTextColumn Header="Bio" Binding="{Binding Bio}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="View Details" Click="ViewDetails_Click"/>
                    <Button Content="Approve Trainer" Margin="8,0,0,0" Click="Approve_Click"/>
                    <Button Content="Reject" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="Reject_Click"/>
                </StackPanel>
            </Grid>
        </TabItem>

        <TabItem Header="All Trainers">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid x:Name="AllTrainersGrid" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="Fee Paid" Binding="{Binding FeePaid}" Width="80"/>
                        <DataGridTextColumn Header="Warnings" Binding="{Binding Warnings}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Send Fee Warning Email" Click="SendWarning_Click"/>
                    <Button Content="Remove from Platform" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="RemoveTrainer_Click"/>
                </StackPanel>
            </Grid>
        </TabItem>

        <TabItem Header="Storage Demo">
            <StackPanel Margin="16">
                <TextBlock Text="Data Storage" FontWeight="Bold" FontSize="16"/>
                <TextBlock Margin="0,8,0,8" TextWrapping="Wrap" Foreground="#65676B"
                           Text="All application data is stored as plain, unencrypted JSON in your local AppData folder. Passwords are still hashed with SHA-256."/>
                <TextBlock x:Name="DataPathText" Foreground="#65676B" TextWrapping="Wrap"/>
                <Button Content="Reload Data from Disk" HorizontalAlignment="Left" Margin="0,12,0,0" Click="ReloadData_Click"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</UserControl>
