<UserControl x:Class="FitnessTrainerPlatform.Views.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="12" Margin="0,0,12,0">
            <StackPanel>
                <TextBlock Text="My Account" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>
                <TextBlock Text="Health issues" Foreground="#65676B"/>
                <TextBox x:Name="HealthBox" AcceptsReturn="True" Height="80" TextWrapping="Wrap" Margin="0,4,0,8"/>
                <Button Content="Save Profile" Click="SaveProfile_Click"/>

                <Separator Margin="0,16"/>

                <TextBlock Text="My Tutelages" FontWeight="Bold" Margin="0,0,0,8"/>
                <ListBox x:Name="MyTutelagesList" Height="120" SelectionChanged="MyTutelagesList_SelectionChanged"/>

                <Button Content="Open Chat" Margin="0,8,0,0" Click="OpenChat_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Browse Fitness Trainers" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="TrainersList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12" Cursor="Hand"
                                    MouseLeftButtonUp="TrainerCard_Click" Tag="{Binding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontSize="18" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding RatingText}" Foreground="#F5A623" Margin="0,4,0,4"/>
                                        <TextBlock Text="{Binding Bio}" TextWrapping="Wrap" Foreground="#65676B" MaxHeight="40"/>
                                        <TextBlock Text="{Binding FeeText}" Margin="0,8,0,0" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="View Profile" VerticalAlignment="Center"
                                            Tag="{Binding}" Click="ViewProfile_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
